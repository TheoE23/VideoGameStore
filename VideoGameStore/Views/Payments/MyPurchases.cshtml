@model List<Purchase>

@{
    ViewData["Title"] = "My Purchases";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">My Library</h1>
            <p class="text-muted mb-0">
                View all games you've purchased
            </p>
        </div>

        <a asp-controller="Games"
           asp-action="Public"
           class="btn btn-dark px-4">
            Browse More Games
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <div class="card-body">

                <div class="mb-4">
                    <i class="bi bi-controller"
                       style="font-size: 4rem;"></i>
                </div>

                <h3 class="fw-semibold mb-3">
                    Your library is empty
                </h3>

                <p class="text-muted mb-4">
                    Purchase games to build your collection.
                </p>

                <a asp-controller="Games"
                   asp-action="Public"
                   class="btn btn-primary px-4">
                    Browse Games
                </a>

            </div>
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var purchase in Model.OrderByDescending(p => p.CreatedAt))
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card border-0 shadow-sm h-100 purchase-card">

                        @if (!string.IsNullOrEmpty(purchase.Game.ImageUrl))
                        {
                            <img src="@purchase.Game.ImageUrl"
                                 class="card-img-top purchase-image"
                                 alt="@purchase.Game.Title" />
                        }
                        else
                        {
                            <div class="purchase-placeholder d-flex align-items-center justify-content-center">
                                <i class="bi bi-controller fs-1"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <div class="mb-3">
                                <h4 class="fw-bold mb-2">
                                    @purchase.Game.Title
                                </h4>

                                <p class="text-muted small mb-0">
                                    Purchased on
                                    @purchase.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy")
                                </p>
                            </div>

                            <div class="mt-auto">

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-muted">
                                        Purchase Price
                                    </span>

                                    <span class="fw-bold fs-5 text-success">
                                        $@purchase.Price.ToString("0.00")
                                    </span>
                                </div>

                                <a asp-controller="Games"
                                   asp-action="Details"
                                   asp-route-id="@purchase.GameId"
                                   class="btn btn-outline-dark w-100">
                                    View Game
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<style>

    .purchase-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 18px;
        overflow: hidden;
    }

        .purchase-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.12) !important;
        }

    .purchase-image {
        height: 220px;
        object-fit: cover;
    }

    .purchase-placeholder {
        height: 220px;
        background: #f1f3f5;
        color: #6c757d;
    }

</style>