@model List<Purchase>

<h2 class="mb-4">My Purchases</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You haven’t purchased any games yet.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var purchase in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@purchase.Game.Title</h5>

                        <p class="card-text">
                            <strong>Price:</strong>
                            $@purchase.Price.ToString("0.00")
                        </p>

                        <p class="card-text">
                            <strong>Purchased:</strong><br />
                            @purchase.CreatedAt.ToLocalTime().ToString("g")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
}