@model IEnumerable<VideoGameStore.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";

    decimal total = Model.Sum(c => c.Game.Price ?? 0);
}
<div class="row g-4">

    <div class="col-lg-8">

        @foreach (var item in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3 overflow-hidden">

                <div class="row g-0 align-items-center">

                    <div class="col-md-3">
                        <img src="@item.Game.ImageUrl"
                             class="img-fluid h-100 w-100"
                             style="object-fit: cover; min-height: 180px;" />
                    </div>

                    <div class="col-md-9">

                        <div class="card-body d-flex justify-content-between align-items-center">

                            <div>
                                <h4 class="fw-semibold mb-2">
                                    @item.Game.Title
                                </h4>

                                <p class="text-muted mb-0">
                                    Added to cart
                                </p>
                            </div>

                            <div class="text-end">

                                <h5 class="fw-bold mb-3">
                                    $@item.Game.Price?.ToString("0.00")
                                </h5>

                                <form asp-action="Remove" method="post">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden"
                                           name="id"
                                           value="@item.Id" />

                                    <button class="btn btn-outline-danger btn-sm rounded-3">
                                        Remove
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

    <div class="col-lg-4">

        <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top">

            <h4 class="fw-bold mb-4">
                Order Summary
            </h4>

            <div class="d-flex justify-content-between mb-3">
                <span>Total</span>
                <strong>$@total.ToString("0.00")</strong>
            </div>

            <form asp-controller="Payments"
                  asp-action="CheckoutCart"
                  method="post">

                @Html.AntiForgeryToken()

                <button class="btn btn-success w-100 py-2 rounded-3">
                    Checkout with PayPal
                </button>

            </form>

        </div>

    </div>

</div>