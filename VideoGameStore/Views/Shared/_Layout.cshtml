<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - NovaPlay</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VideoGameStore.styles.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        html {
            min-height: 100%;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #1e293b 0%, #0f172a 45%, #020617 100%);
        }

        main {
            flex: 1 !important;
        }

        .navbar-modern {
            background: rgba(2, 6, 23, 0.82);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .navbar-brand {
            font-size: 1.6rem;
            font-weight: 800;
            color: #ffffff !important;
            letter-spacing: 0.5px;
            transition: 0.2s ease;
        }

            .navbar-brand:hover {
                opacity: 0.9;
            }

        .navbar-modern .nav-link {
            color: #cbd5e1 !important;
            font-weight: 500;
            transition: 0.2s ease;
            position: relative;
        }

            .navbar-modern .nav-link:hover {
                color: #ffffff !important;
            }

                .navbar-modern .nav-link:hover::after {
                    width: 100%;
                }

            .navbar-modern .nav-link::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -5px;
                width: 0;
                height: 2px;
                background: #3b82f6;
                transition: width 0.2s ease;
            }

        .navbar-actions .btn {
            border-radius: 10px;
            font-weight: 500;
        }

        .page-wrapper {
            max-width: 1450px;
        }

        .card {
            border: none;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            transition: 0.25s ease;
        }

            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 40px rgba(0,0,0,0.18);
            }

        .btn-primary {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            border: none;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, #1d4ed8, #2563eb);
            }

        .btn-outline-light:hover {
            color: #000;
        }

        .footer-modern {
            background: linear-gradient(90deg, #020617, #0f172a);
            border-top: 1px solid rgba(255,255,255,0.05);
            min-height: 68px;
            display: flex;
            align-items: center;
            margin-top: auto;
        }

            .footer-modern .container-fluid {
                min-height: 68px;
            }

        .footer-text {
            color: #94a3b8;
            font-size: 0.92rem;
            margin: 0;
        }

        .footer-link {
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.92rem;
            transition: 0.2s ease;
        }

            .footer-link:hover {
                color: white;
            }

        .social-icon,
        .social-icon i {
            color: #e2e8f0 !important;
            font-size: 1.25rem;
            transition: 0.2s ease;
            text-decoration: none;
            opacity: 0.85;
        }

            .social-icon:hover,
            .social-icon:hover i {
                color: #ffffff !important;
                opacity: 1;
                transform: translateY(-2px) scale(1.08);
            }

        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #020617;
        }

        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 999px;
        }

        ::-webkit-scrollbar-thumb:hover {
                background: #475569;
        }

    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-modern sticky-top shadow-sm">

            <div class="container-fluid px-4 px-lg-5">
                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/images/novaplay-logo.png"
                         asp-append-version="true"
                         alt="NovaPlay Logo"
                         style="height: 55px; width: auto;" />

                    <span>NovaPlay</span>
                </a>
                <button class="navbar-toggler bg-light"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse"
                     id="navbarContent">
                    <ul class="navbar-nav ms-4 gap-3">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Games"
                               asp-action="Public">
                                Games
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Payments"
                                   asp-action="MyPurchases">
                                    My Library
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-controller="Admin"
                                   asp-action="Index">
                                    Admin
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto navbar-actions align-items-center">

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <form asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      method="post">

                                    <button class="btn btn-outline-light btn-sm px-3">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-light btn-sm px-3"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">

                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">

                                    Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="py-4">
        <div class="container page-wrapper">
            @RenderBody()
        </div>
    </main>
    <footer class="footer-modern">
        <div class="container-fluid px-5 d-flex justify-content-between align-items-center">

            <span class="footer-text">
                © 2026 NovaPlay. All rights reserved.
            </span>

            <div class="d-flex align-items-center gap-4">

                <a class="footer-link"
                   asp-controller="Home"
                   asp-action="Privacy">
                    Privacy
                </a>
                <div class="d-flex align-items-center gap-3">

                    <a href="#" class="social-icon">
                        <i class="bi bi-twitter-x"></i>
                    </a>

                    <a href="#" class="social-icon">
                        <i class="bi bi-discord"></i>
                    </a>

                    <a href="#" class="social-icon">
                        <i class="bi bi-instagram"></i>
                    </a>

                    <a href="#" class="social-icon">
                        <i class="bi bi-youtube"></i>
                    </a>

                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
