@model VideoGameStore.ViewModels.GameDetailsViewModel

@{
    ViewData["Title"] = Model.Game.Title;
    var alreadyOwned = Model.Purchases.Any(p => p.GameId == Model.Game.Id);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 overflow-hidden mb-4">

        @if (!string.IsNullOrEmpty(Model.Game.ImageUrl))
        {
            <div class="position-relative">

                <img src="@Model.Game.ImageUrl"
                     class="w-100 details-banner"
                     alt="@Model.Game.Title" />

                <div class="details-overlay"></div>

                <div class="details-title position-absolute bottom-0 start-0 p-4 text-white">
                    <h1 class="fw-bold mb-2">
                        @Model.Game.Title
                    </h1>

                    <p class="mb-0 opacity-75">
                        @Model.Game.Developer?.Name
                    </p>
                </div>

            </div>
        }

        <div class="card-body">

            

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Developer:</strong> @Model.Game.Developer?.Name</p>
                    <p>
                        <strong>Categories:</strong>
                        @string.Join(", ", Model.Game.GameCategories.Select(gc => gc.Category.Name))
                    </p>
                </div>

                <div class="col-md-6 text-md-end">
                    @if (Model.Game.Price.HasValue)
                    {
                        <h4 class="text-success">$@Model.Game.Price.Value.ToString("0.00")</h4>
                    }
                    else
                    {
                        <h4 class="text-muted">Free</h4>
                    }
                </div>
                @if (alreadyOwned)
                {
                    <div class="alert alert-success mt-2">
                        You already own this game.
                    </div>
                }
                else if (Model.Game.Price.HasValue)
                {
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-controller="Payments"
                              asp-action="CreateOrder"
                              method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="gameId"
                                   value="@Model.Game.Id" />

                            <button class="btn btn-success">
                                Buy for $@Model.Game.Price.Value.ToString("0.00")
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity"
                           asp-page="/Account/Login"
                           class="btn btn-outline-dark btn-lg">
                            Log in to Purchase
                        </a>
                    }
                }
                else
                {
                    <p class="text-muted">Not available for purchase</p>
                }
            </div>

        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h4 class="mb-3">Reviews</h4>

            @if (!Model.Reviews.Any())
            {
                <p class="text-muted">No reviews yet. Be the first to review!</p>
            }
            else
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <strong>@review.User?.UserName</strong>
                            <span> - @review.Rating / 5</span>

                            <p>@review.Content</p>

                            @if (User.IsInRole("Moderator") || User.IsInRole("Admin"))
                            {
                                <form asp-action="ReportReview" method="post" class="mt-2">
                                    <input type="hidden" name="reviewId" value="@review.Id" />

                                    <select name="reason" class="form-control">
                                        <option>Spam</option>
                                        <option>Offensive</option>
                                        <option>Harassment</option>
                                        <option>Other</option>
                                    </select>

                                    <button class="btn btn-sm btn-danger">
                                        Report
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="mb-3">Write a Review</h4>

                <form asp-action="AddReview" method="post">
                    <input type="hidden" name="Game.Id" value="@Model.Game.Id" />

                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <select name="NewReviewRating" class="form-select">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <option value="@i">@i Stars</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Review</label>
                        <textarea name="NewReviewContent" class="form-control" rows="4" placeholder="Write your thoughts..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Submit Review
                    </button>
                </form>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You must be logged in to leave a review.
        </div>
    }

</div>

<style>

    .details-banner {
        height: 380px;
        object-fit: cover;
    }

    .details-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0,0,0,0.75), rgba(0,0,0,0.1) );
    }

    .details-title {
        z-index: 2;
    }

</style>