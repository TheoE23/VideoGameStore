@model VideoGameStore.ViewModels.GameDetailsViewModel

@{
    ViewData["Title"] = Model.Game.Title;
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h2 class="mb-3">@Model.Game.Title</h2>

            <div class="row">
                <div class="col-md-6">
                    <p><strong>Developer:</strong> @Model.Game.Developer?.Name</p>
                    <p>
                        <strong>Categories:</strong>
                        @string.Join(", ", Model.Game.GameCategories.Select(gc => gc.Category.Name))
                    </p>
                </div>

                <div class="col-md-6 text-md-end">
                    @if (Model.Game.Price.HasValue)
                    {
                        <h4 class="text-success">$@Model.Game.Price.Value.ToString("0.00")</h4>
                    }
                    else
                    {
                        <h4 class="text-muted">Free</h4>
                    }
                </div>
            </div>

        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h4 class="mb-3">Reviews</h4>

            @if (!Model.Reviews.Any())
            {
                <p class="text-muted">No reviews yet. Be the first to review!</p>
            }
            else
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <strong>@review.User?.UserName</strong>
                            <span> - @review.Rating / 5</span>

                            <p>@review.Content</p>

                            @if (User.IsInRole("Moderator") || User.IsInRole("Admin"))
                            {
                                <form asp-action="ReportReview" method="post" class="mt-2">
                                    <input type="hidden" name="reviewId" value="@review.Id" />

                                    <select name="reason" class="form-control">
                                        <option>Spam</option>
                                        <option>Offensive</option>
                                        <option>Harassment</option>
                                        <option>Other</option>
                                    </select>

                                    <button class="btn btn-sm btn-danger">
                                        Report
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="mb-3">Write a Review</h4>

                <form asp-action="AddReview" method="post">
                    <input type="hidden" name="Game.Id" value="@Model.Game.Id" />

                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <select name="NewReviewRating" class="form-select">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <option value="@i">@i Stars</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Review</label>
                        <textarea name="NewReviewContent" class="form-control" rows="4" placeholder="Write your thoughts..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Submit Review
                    </button>
                </form>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You must be logged in to leave a review.
        </div>
    }

</div>