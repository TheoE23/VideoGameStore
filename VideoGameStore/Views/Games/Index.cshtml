@model IEnumerable<VideoGameStore.Models.Game>
@using System.Globalization

@{
    ViewData["Title"] = "Manage Games";
    var developers = ViewBag.Developers as List<VideoGameStore.Models.Developer>;
    var categories = ViewBag.Categories as List<VideoGameStore.Models.Category>;
}

<h1>Manage Games</h1>

<hr />

<h4>Add New Game</h4>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="Title" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Developer</label>
        <select name="DeveloperId" class="form-select" required>
            <option value="" disabled selected>-- Select Developer --</option>
            @foreach (var dev in developers)
            {
                <option value="@dev.Id">@dev.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Categories</label>
        @foreach (var cat in categories)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="selectedCategories"
                       value="@cat.Id" />
                <label class="form-check-label">
                    @cat.Name
                </label>
            </div>
        }
    </div>

    <div class="mb-3">
        <label class="form-label">Price</label>
        <input name="Price" class="form-control" placeholder="e.g. 59.99" />
    </div>

    <div class="mb-3">
        <label class="form-label">Published</label>
        <select name="IsPublished" class="form-select">
            <option value="true" selected>Yes</option>
            <option value="false">No</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Add Game
    </button>
</form>

<hr />

<form asp-action="ImportTopGames" method="post" class="mb-3">
    @Html.AntiForgeryToken()

    <button type="submit"
            class="btn btn-warning"
            onclick="return confirm('Import top 50 games from RAWG?');">
        Import Top 50 Games (RAWG)
    </button>
</form>

<form asp-action="RefreshImages" method="post">
    @Html.AntiForgeryToken()

    <button class="btn btn-warning">
        Refresh RAWG Images
    </button>
</form>

<h4 class="pt-2 mb-4">Existing Games</h4>

<div class="d-flex flex-column gap-3">

    @foreach (var game in Model)
    {
        <div class="card shadow-sm border-0">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <div class="d-flex align-items-center gap-3">

                        @if (!string.IsNullOrEmpty(game.ImageUrl))
                        {
                            <img src="@game.ImageUrl"
                                 style="width: 120px; height: 70px; object-fit: cover; border-radius: 10px;" />
                        }

                        <div>
                            <h5 class="mb-1">@game.Title</h5>

                            <div class="text-muted small">
                                @game.Developer?.Name
                            </div>

                            <div class="small mt-1">
                                <strong>Price:</strong>
                                @(game.Price?.ToString("0.00") ?? "N/A")
                            </div>

                            <div class="small">
                                <strong>Status:</strong>
                                @(game.IsPublished ? "Published" : "Hidden")
                            </div>
                        </div>

                    </div>

                    <div class="d-flex gap-2">

                        <button class="btn btn-sm btn-dark"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#edit-@game.Id">
                            Edit
                        </button>

                        <form asp-action="Delete"
                              method="post"
                              onsubmit="return confirm('Delete this game?');">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="Id"
                                   value="@game.Id" />

                            <button class="btn btn-sm btn-danger">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>

                <div class="collapse mt-4"
                     id="edit-@game.Id">

                    <form asp-action="Edit"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="Id"
                               value="@game.Id" />

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label">Title</label>

                                <input name="Title"
                                       value="@game.Title"
                                       class="form-control" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Price</label>

                                <input name="Price"
                                       value="@game.Price?.ToString("0.00", CultureInfo.InvariantCulture)"
                                       class="form-control" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Published</label>

                                <select name="IsPublished"
                                        class="form-select">

                                    <option value="true"
                                            selected="@game.IsPublished">
                                        Yes
                                    </option>

                                    <option value="false"
                                            selected="@(game.IsPublished == false)">
                                        No
                                    </option>

                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Developer</label>

                                <select name="DeveloperId"
                                        class="form-select">

                                    @foreach (var dev in developers)
                                    {
                                        <option value="@dev.Id"
                                                selected="@(dev.Id == game.DeveloperId)">
                                            @dev.Name
                                        </option>
                                    }

                                </select>
                            </div>

                            <div class="col-12">

                                <label class="form-label">
                                    Categories
                                </label>

                                <div class="row">

                                    @foreach (var cat in categories)
                                    {
                                        <div class="col-md-3">

                                            <div class="form-check">

                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="selectedCategories"
                                                       value="@cat.Id"
                                                       checked="@game.GameCategories.Any(gc => gc.CategoryId == cat.Id)" />

                                                <label class="form-check-label">
                                                    @cat.Name
                                                </label>

                                            </div>

                                        </div>
                                    }

                                </div>

                            </div>

                            <div class="col-12">

                                <button type="submit"
                                        class="btn btn-success">
                                    Save Changes
                                </button>

                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    }

</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>

                </li>
            }

        </ul>

    </nav>
}