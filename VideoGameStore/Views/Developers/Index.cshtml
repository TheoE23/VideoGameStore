@model IEnumerable<VideoGameStore.Models.Developer>

@{
    ViewData["Title"] = "Manage Developers";
}

<h1>Manage Developers</h1>

<hr />

<h4>Add New Developer</h4>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input name="Name" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary">Add</button>
</form>

<hr />

<h4>Existing Developers</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th style="width: 180px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dev in Model)
        {
            <tr>
                <td>
                    <form asp-action="Edit" method="post" class="d-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@dev.Id" />
                        <input name="Name" value="@dev.Name" class="form-control me-2" />
                        <button type="submit" class="btn btn-sm btn-success">
                            Save
                        </button>
                    </form>
                </td>
                <td>
                    <form asp-action="Delete" method="post"
                          onsubmit="return confirm('Delete this developer?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@dev.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>

                </li>
            }

        </ul>

    </nav>
}
