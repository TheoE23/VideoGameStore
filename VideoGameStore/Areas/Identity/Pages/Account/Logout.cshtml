@page
@model LogoutModel

@{
    ViewData["Title"] = "Log out";
}

<div class="d-flex justify-content-center align-items-center py-5">

    <div class="card shadow-sm border-0 rounded-4 p-5 text-center"
         style="max-width: 500px; width: 100%;">

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="mb-4">

                <div class="logout-icon mb-3">
                    ↩
                </div>

                <h2 class="fw-bold mb-2">
                    Ready to leave?
                </h2>

                <p class="text-muted mb-0">
                    You are about to log out of your NovaPlay account.
                </p>

            </div>

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Page("/", new { area = "" })"
                  method="post">

                <button type="submit"
                        class="btn btn-dark px-5 py-2 rounded-3">
                    Confirm Logout
                </button>

            </form>
        }
        else
        {
            <div class="mb-4">

                <div class="logout-icon success mb-3">
                    ✓
                </div>

                <h2 class="fw-bold mb-2">
                    Logged out successfully
                </h2>

                <p class="text-muted mb-4">
                    Your session has ended safely.
                </p>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-primary px-4 py-2 rounded-3">
                    Return Home
                </a>

            </div>
        }

    </div>

</div>

<style>
    .logout-icon {
        width: 72px;
        height: 72px;
        margin: 0 auto;
        border-radius: 50%;
        background: rgba(15, 23, 42, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: bold;
        color: #0f172a;
    }

        .logout-icon.success {
            background: rgba(34, 197, 94, 0.12);
            color: #16a34a;
        }
</style>